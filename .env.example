# ============================================
# 🔐 VARIÁVEIS DE AMBIENTE - GRANDPORT ERP
# ============================================
#
# INSTRUÇÕES:
# 1. Copie este arquivo para .env (NUNCA commite .env!)
# 2. Preencha com seus valores reais
# 3. Cada variável é importante para o sistema funcionar
#
# ============================================

# 🔑 SEGURANÇA - JWT TOKEN
# ============================================
# Chave secreta para assinar tokens JWT
# Mude para algo bem seguro em produção!
# Exemplo: "sua-chave-super-secreta-1234567890-aleatória"
JWT_SECRET=sua-chave-super-secreta-123

# ============================================
# 🗄️ BANCO DE DADOS - PostgreSQL
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=grandport_erp
DB_USER=postgres
DB_PASSWORD=admin

# ============================================
# 🌐 CONFIGURAÇÃO DE REDE
# ============================================
# URL base da API (mude se publicar em produção)
APP_BASE_URL=http://192.168.1.104:8080

# ============================================
# 📧 EMAIL - Gmail/SMTP
# ============================================
# Para enviar XMLs, boletos, etc.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-senha-app-do-gmail

# ✅ Como gerar senha de app Gmail:
#    1. Acesse: https://myaccount.google.com/security
#    2. Ative "Autenticação em duas etapas"
#    3. Vá em "Senhas de app"
#    4. Selecione "Mail" e "Windows/Mac/Linux"
#    5. Use a senha gerada aqui (16 caracteres sem espaços)

# ============================================
# 💬 WHATSAPP - Evolution API
# ============================================
# Token para integração com WhatsApp
EVOLUTION_API_KEY=MEU_TOKEN_SECRETO_123

# URL da Evolution API
EVOLUTION_API_URL=http://localhost:8081

# ============================================
# 📊 NFe - Documento Fiscal
# ============================================
# Seu CNPJ (sem máscara)
NFE_CNPJ=26260314074903

# Série NFe
NFE_SERIE=1

# Número inicial NFe
NFE_NUMERO_INICIAL=1

# ============================================
# 🔍 LOG LEVEL
# ============================================
# Níveis: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=DEBUG

# ============================================
# 🚀 AMBIENTE
# ============================================
# Valores: development, staging, production
ENVIRONMENT=development

# ============================================
# 🎯 CONFIGURAÇÕES DE SERVIDOR
# ============================================
SERVER_PORT=8080
SERVER_ADDRESS=localhost

# ============================================
# 📱 MOBILE - URLs
# ============================================
# URL para conectar o app mobile à API
MOBILE_API_URL=http://192.168.1.104:8080
# Altere 192.168.1.104 para o IP do seu computador na rede!
# Descubra seu IP:
#   Windows: ipconfig | findstr "IPv4"
#   macOS/Linux: ifconfig | grep inet

# ============================================
# 🗝️ NOTAS IMPORTANTES
# ============================================
#
# 1. NUNCA commite o arquivo .env com dados reais!
#    - Use: .gitignore contém: .env
#
# 2. Para desenvolvimento local, valide .env.example
#    - Todos devem ter os mesmos valores de teste
#
# 3. Em PRODUÇÃO, configure via variáveis do sistema:
#    export JWT_SECRET="..."
#    export DB_PASSWORD="..."
#    # etc
#
# 4. SEGURANÇA:
#    - JWT_SECRET: Altere em produção
#    - DB_PASSWORD: Use senha forte
#    - MAIL_PASSWORD: Use senha de app, nunca a senha real
#    - Não commite dados sensíveis!
#
# ============================================

