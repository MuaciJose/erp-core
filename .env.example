# ============================================
# VARIAVEIS DE AMBIENTE - GRANDPORT ERP
#
# Uso com docker-compose:
# 1. Copie para .env
# 2. Preencha os valores reais
# 3. Suba com: docker compose up -d --build
#
# Em hml/producao, Redis e obrigatorio para autenticacao segura.

# PERFIL DA APLICACAO
SPRING_PROFILES_ACTIVE=hml

# SEGURANCA
JWT_SECRET=troque-por-uma-chave-longa-e-segura
APP_SECURITY_REDIS_REQUIRED=true
APP_SECURITY_COOKIE_SECURE=true
APP_SECURITY_COOKIE_SAME_SITE=Lax
APP_BILLING_WEBHOOK_TOKEN=troque-por-um-token-de-webhook

# POSTGRES
POSTGRES_DB=grandport_erp
POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin
POSTGRES_PORT=5432

# REDIS
REDIS_PORT=6379

# APP
APP_PORT=8080
APP_API_BASE_URL=https://api.seu-dominio.com

# EMAIL / SMTP
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-senha-app-do-gmail

# WHATSAPP / EVOLUTION
EVOLUTION_API_KEY=MEU_TOKEN_SECRETO_123
EVOLUTION_API_URL=http://localhost:8081

# FISCAL
NFE_CNPJ=26260314074903
NFE_SERIE=1
NFE_NUMERO_INICIAL=1

# LOG
LOG_LEVEL=DEBUG

# MOBILE
MOBILE_API_URL=https://api.seu-dominio.com
